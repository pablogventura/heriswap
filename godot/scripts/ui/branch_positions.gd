static func to_screen(gimp: Vector3, viewport: Vector2 = Vector2(800, 1280)) -> Dictionary:
	return {
		"position": Vector2(gimp.x / 800.0 * viewport.x, gimp.y / 1280.0 * viewport.y),
		"rotation": deg_to_rad(gimp.z),
	}